<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RemindIo.RemindersPage"
             Title="Moje przypomnienia"
             BackgroundColor="#00257a">

    <CollectionView x:Name="remindersList">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Frame Margin="15"
       Padding="15"
       BackgroundColor="Black"
       CornerRadius="15"
       HasShadow="True">

                    <VerticalStackLayout Spacing="10">

                        <!-- Tytuł -->
                        <Label Text="{Binding Title}"
       FontAttributes="Bold"
       FontSize="20"
       TextColor="#00257a"/>

                        <!-- Opis -->
                        <Label Text="{Binding Description}"
       FontSize="14"
       TextColor="Gray"/>

                        <!-- Godziny -->
                        <HorizontalStackLayout Spacing="5">

                            <Label Text="🕒"/>

                            <Label Text="{Binding StartTime}"
       FontSize="13"/>

                            <Label Text="-"/>

                            <Label Text="{Binding EndTime}"
       FontSize="13"/>

                        </HorizontalStackLayout>

                        <!-- Lokalizacja -->
                        <HorizontalStackLayout Spacing="5">

                            <Label Text="📍"/>

                            <Label Text="{Binding Latitude}"
       FontSize="12"/>

                            <Label Text=","
       FontSize="12"/>

                            <Label Text="{Binding Longitude}"
       FontSize="12"/>

                        </HorizontalStackLayout>

                        <!-- Zdjęcie -->
                        <Image Source="{Binding PhotoPath}"
       HeightRequest="150"
       Aspect="AspectFill"/>

                        <!-- Przyciski -->
                        <HorizontalStackLayout Spacing="10">

                            <Button Text="Edytuj"
        BackgroundColor="#5bc0de"
        TextColor="White"
        CornerRadius="10"
        Clicked="EditReminderClicked"
        CommandParameter="{Binding .}"/>

                            <Button Text="Usuń"
        BackgroundColor="#d9534f"
        TextColor="White"
        CornerRadius="10"
        Clicked="DeleteReminderClicked"
        CommandParameter="{Binding .}"/>

                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                </Frame>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>